```gitignore
# Compiled Python files
*.pyc
__pycache__/

# Virtual environments
venv/
.venv/
.env
.env.local
*.env.*

# Logs
*.log

# Editor/IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Build/dist directories
dist/
build/
target/

# Dependencies
node_modules/
.mypy_cache/
.pytest_cache/
coverage/
htmlcov/
.coverage

# System files
.DS_Store
Thumbs.db
```